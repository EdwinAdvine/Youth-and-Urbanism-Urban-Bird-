# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=urbanbird_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=urbanbird_db

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=urbanbird_redis_dev

# ─── JWT ────────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_very_long_random_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── M-Pesa (Safaricom Daraja API) ──────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_test_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_test_public_key
# REQUIRED — webhook requests are rejected if this is not set
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@urbanbird.co.ke
FROM_NAME=Urban Bird

# ─── SMS (Africa's Talking) ──────────────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=URBANBIRD

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

# ─── Storage ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE_MB=5
